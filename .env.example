# X (Twitter) API credentials — OAuth 1.0a user context.
# Create an app at https://developer.x.com (free tier works: 500 posts/month),
# set app permissions to "Read and write", then generate these four values.
# Copy this file to .env (which is gitignored) and fill them in.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Base URL of the published site (used in post links).
SITE_BASE=https://cayblood.github.io/ai-safety-study-plan
